{
  "name": "@hendacorp/source",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@8.14.0",
  "volta": {
    "node": "18.19.0",
    "pnpm": "8.14.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/akhenda/hendacorp"
  },
  "nx": {
    "includedScripts": []
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "gc": "git add . && cz",
    "gc-ai": "git add . && npx czg ai -N=5",
    "prepare": "husky install",
    "help": "nx help",
    "affected": "nx affected",
    "affected:apps": "nx affected:apps",
    "affected:libs": "nx affected:libs",
    "nx": "pnpm exec nx",
    "nx:update": "nx migrate latest",
    "nx:test": "pnpm exec nx test",
    "nx:reset": "pnpm exec nx reset"
  },
  "devDependencies": {
    "@commitlint/cli": "17.8.1",
    "@commitlint/config-conventional": "17.8.1",
    "@commitlint/config-nx-scopes": "17.8.1",
    "@hendacorp/eslint-plugin": "workspace:*",
    "@nx/eslint-plugin": "16.10.0",
    "@nx/jest": "16.10.0",
    "@nx/js": "16.10.0",
    "@nx/linter": "16.10.0",
    "@nx/workspace": "16.10.0",
    "@swc/cli": "0.1.63",
    "@swc/core": "1.3.102",
    "@swc/jest": "0.2.29",
    "@theunderscorer/nx-semantic-release": "2.10.0",
    "@types/jest": "29.5.11",
    "@types/node": "20.10.7",
    "cz-git": "1.8.0",
    "eslint": "8.56.0",
    "husky": "8.0.3",
    "jest": "29.7.0",
    "jest-environment-node": "29.7.0",
    "lint-staged": "15.2.0",
    "nx": "16.10.0",
    "nx-cloud": "16.5.2",
    "prettier": "3.1.1",
    "ts-jest": "29.1.1",
    "ts-node": "10.9.2",
    "typescript": "5.3.3",
    "verdaccio": "5.29.0"
  },
  "dependencies": {
    "@swc/helpers": "0.5.3",
    "tslib": "2.6.2"
  }
}
